# Imagen base oficial de N8N (Debian/Ubuntu)
FROM docker.n8n.io/n8nio/n8n:latest

# Cambiamos a root para instalar paquetes
USER root

# Instalar Python 3, pip y openpyxl
# --break-system-packages es necesario en Python 3.11+ (PEP 668)
RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir --break-system-packages openpyxl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Volvemos al usuario por defecto de N8N
USER node
